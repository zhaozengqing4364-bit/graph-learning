{
  "name": "axon-clone",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agent-workflows": "./scripts/install-agent-workflows.mjs",
    "awf": "./scripts/install-agent-workflows.mjs"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "uv run --directory . uvicorn backend.main:app --reload --port 8000",
    "dev:tauri": "tauri dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "build:tauri": "tauri build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:all": "vitest run && .venv/bin/python -m pytest backend/tests/ -q",
    "test:watch": "vitest",
    "preview": "vite preview",
    "agent:install": "node scripts/install-agent-workflows.mjs",
    "agent:install:codex": "node scripts/install-agent-workflows.mjs --agent codex",
    "agent:install:claude": "node scripts/install-agent-workflows.mjs --agent claude",
    "agent:install:both": "node scripts/install-agent-workflows.mjs --agent both",
    "agent:link": "npm link"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@xyflow/react": "^12.0.0",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
